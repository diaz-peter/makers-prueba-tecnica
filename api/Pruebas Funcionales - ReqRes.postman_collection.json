          "listen": "test",
          "script": {
            "exec": [
              "// 1. Verificar código de estado 200\r",
              "pm.test(\"Status code es 200 - Usuario Encontrado\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Verificar que los datos coincidan (Ejemplo adaptado a un ID real como el /users/2)\r",
              "pm.test(\"El nombre y trabajo coinciden con lo esperado\", function () {\r",
              "    const jsonData = pm.response.json().data;\r",
              "    \r",
              "    // Si estás usando /users/2 para simular el éxito:\r",
              "    pm.expect(jsonData.first_name).to.eql(\"Janet\");     \r",
              "    \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
