  "item": [
    {
      "name": "Solicitud POST (Crear Usuario)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validar código de estado 201\r",
              "pm.test(\"Status code es 201 - Usuario Creado\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea un JSON válido y tenga la estructura correcta\r",
              "pm.test(\"La respuesta contiene name, job e id\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('name', 'Test User');\r",
              "    pm.expect(jsonData).to.have.property('job', 'Automation Engineer');\r",
              "    pm.expect(jsonData).to.have.property('id');\r",
              "});\r",
              "\r",
              "// 3. EXTRAER EL ID Y GUARDARLO EN UNA VARIABLE de la colección\r",
              "const userId = pm.response.json().id;\r",
              "pm.collectionVariables.set(\"new_user_id\", userId);\r",
              "console.log(\"ID guardado exitosamente: \" + userId);\r",
              "\r",
              "pm.test(\"El tiempo de respuesta es menor a 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"Test User\",\r\n    \"job\": \"Automation Engineer\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Solicitud GET (Validar Usuario Creado)",
